{
  "name": "api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "migrate": "tsx --env-file=.env src/db/migrate.ts",
    "test": "node --experimental-test-module-mocks --import tsx/esm --test src/**/*.test.ts",
    "test:coverage": "node --experimental-test-module-mocks --import tsx/esm --test --experimental-test-coverage --test-coverage-exclude='src/db/**' --test-coverage-exclude='src/index.ts' --test-coverage-exclude='src/lib/realtime.ts' 'src/**/*.test.ts'",
    "seed:admin": "tsx --env-file=.env src/db/seed-admin.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.4.0",
    "@repo/shared": "workspace:*",
    "hono": "^4.5.0",
    "jose": "^5.9.0",
    "postgres": "^3.4.4",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}